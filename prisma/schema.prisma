// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  USER
  ADMIN
  MASTER_ADMIN
}

enum CashMode {
  USD
  EUR
  CHF
  TRY_REPO
}

enum TradeSide {
  BUY
  SELL
}

enum DisplayNameMode {
  REAL_NAME
  NICKNAME
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum LeagueType {
  ROTARY
  ROTARACT
  INTERACT
  PRIVATE
  GENERAL
}

enum LeagueRole {
  MEMBER
  MODERATOR
  OWNER
}

enum CompetitionPeriodType {
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  YEARLY
}

enum SiteVisualSettingType {
  TEXT
  COLOR
  IMAGE_URL
  BOOLEAN
}

enum ManagedContentType {
  ANNOUNCEMENT
  BLOG
  EDUCATION
  CONTACT
}

enum ChatRoomType {
  GENERAL
  PRIVATE
}

enum ChatMessageType {
  TEXT
  FILE
  IMAGE
  VIDEO
  LOCATION
  CONTACT
  POLL
}

model User {
  id                                  String    @id @default(cuid())
  name                                String
  nickname                            String?
  displayNameMode                     DisplayNameMode @default(REAL_NAME)
  email                               String    @unique
  passwordHash                        String?
  isActive                            Boolean   @default(false)
  emailVerifiedAt                     DateTime?
  emailVerificationTokenHash          String?
  emailVerificationExpiresAt          DateTime?
  emailVerificationSentAt             DateTime?
  role                                Role      @default(USER)
  score                               Int       @default(0)
  kvkkDisclosureAccepted              Boolean   @default(false)
  kvkkDisclosureAcceptedAt            DateTime?
  termsAccepted                       Boolean   @default(false)
  termsAcceptedAt                     DateTime?
  noInvestmentAdviceAccepted          Boolean   @default(false)
  noInvestmentAdviceAcceptedAt        DateTime?
  electronicCommunicationConsent      Boolean   @default(false)
  electronicCommunicationConsentAt    DateTime?
  createdAt                           DateTime  @default(now())
  updatedAt                           DateTime  @updatedAt
  virtualAccount                      VirtualAccount?
  positions                           PortfolioPosition[]
  trades                              VirtualTrade[]
  sentFriendRequests                  FriendRequest[] @relation("SentFriendRequests")
  receivedFriendRequests              FriendRequest[] @relation("ReceivedFriendRequests")
  createdLeagues                      League[] @relation("CreatedLeagues")
  leagueMemberships                   LeagueMembership[]
  badges                              UserBadge[]
  achievementEvents                   AchievementEvent[]
  portfolioSnapshots                  PortfolioSnapshot[]
  oauthAccounts                       OAuthAccount[]
  aiMarketFavorites                   AiMarketFavorite[]
  aiMarketReports                     AiMarketReport[]
  aiMarketReportEvents                AiMarketReportEvent[]
  subscriptionEmailLogs               SubscriptionEmailLog[]
  createdChatRooms                    ChatRoom[] @relation("CreatedChatRooms")
  chatMessages                        ChatMessage[]
  chatPresences                       ChatPresence[]
  chatPollVotes                       ChatPollVote[]
}

model OAuthAccount {
  id                String   @id @default(cuid())
  provider          String
  providerAccountId String
  userId            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model BlogPost {
  id        String   @id @default(cuid())
  slug      String   @unique
  titleTr   String
  titleEn   String
  excerptTr String
  excerptEn String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdPlacement {
  id              String   @id @default(cuid())
  slot            String
  title           String
  body            String
  imageUrl        String?
  videoUrl        String?
  linkUrl         String?
  linkLabel       String?
  isActive        Boolean  @default(true)
  displaySeconds  Int      @default(8)
  priority        Int      @default(0)
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slot, isActive, priority])
}

model ManagedContentPage {
  id        String   @id @default(cuid())
  code      String   @unique
  title     String
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ManagedContentItem {
  id          String             @id @default(cuid())
  type        ManagedContentType
  locale      String             @default("tr")
  title       String
  excerpt     String?
  body        String
  imageUrl    String?
  videoUrl    String?
  linkUrl     String?
  linkLabel   String?
  sortOrder   Int                @default(0)
  isFeatured  Boolean            @default(false)
  isActive    Boolean            @default(true)
  publishedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([type, locale, isActive, sortOrder])
  @@index([isFeatured, isActive])
}

model SiteVisualSetting {
  id          String                @id @default(cuid())
  key         String                @unique
  title       String
  value       String
  type        SiteVisualSettingType
  description String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([type])
}

model VirtualAccount {
  id                 String   @id @default(cuid())
  userId             String   @unique
  cashMode           CashMode @default(USD)
  cashAmount         Float    @default(1000000)
  baseCurrency       String   @default("USD")
  dailyRepoRate      Float    @default(0.00125)
  repoLastAccruedAt  DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PortfolioPosition {
  id              String   @id @default(cuid())
  userId          String
  symbol          String
  name            String
  market          String
  quantity        Float
  averagePriceUsd Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
}

model VirtualTrade {
  id          String    @id @default(cuid())
  userId      String
  symbol      String
  name        String
  market      String
  side        TradeSide
  quantity    Float
  priceUsd    Float
  totalUsd    Float
  reason      String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model FriendRequest {
  id          String              @id @default(cuid())
  pairKey     String              @unique
  senderId    String
  receiverId  String
  status      FriendRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  sender      User                @relation("SentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User                @relation("ReceivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, status])
  @@index([receiverId, status])
}

model League {
  id              String             @id @default(cuid())
  name            String
  slug            String             @unique
  description     String?
  type            LeagueType
  inviteCode      String             @unique
  createdByUserId String
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  createdBy       User               @relation("CreatedLeagues", fields: [createdByUserId], references: [id], onDelete: Cascade)
  memberships     LeagueMembership[]

  @@index([type, isActive])
  @@index([createdByUserId])
}

model LeagueMembership {
  id        String     @id @default(cuid())
  leagueId  String
  userId    String
  role      LeagueRole @default(MEMBER)
  joinedAt  DateTime   @default(now())
  league    League     @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId])
  @@index([userId])
}

model Badge {
  id            String      @id @default(cuid())
  code          String      @unique
  nameTr        String
  nameEn        String
  descriptionTr String
  descriptionEn String
  icon          String
  category      String
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  users         UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([badgeId])
}

model AchievementEvent {
  id        String   @id @default(cuid())
  userId    String
  type      String
  metadata  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model CompetitionPeriod {
  id        String                @id @default(cuid())
  type      CompetitionPeriodType
  name      String
  startsAt  DateTime
  endsAt    DateTime
  isActive  Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  snapshots PortfolioSnapshot[]

  @@index([type, isActive])
  @@index([startsAt, endsAt])
}

model PortfolioSnapshot {
  id                String            @id @default(cuid())
  userId            String
  periodId          String
  portfolioValueUsd Float
  cashUsd           Float
  positionsValueUsd Float
  returnPercent     Float
  rank              Int?
  capturedAt        DateTime          @default(now())
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  period            CompetitionPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([userId, periodId])
  @@index([periodId, rank])
  @@index([userId])
}

model AiSignalLog {
  id                  String               @id @default(cuid())
  createdAt           DateTime             @default(now())
  symbol              String
  displayName         String?
  exchange            String?
  interval            String
  signalType          String
  recommendationText  String?
  confidence          Float?
  riskScore           Float?
  opportunityScore    Float?
  priceAtSignal       Float?
  currency            String?
  source              String?
  reason              String?
  indicatorsSnapshot  Json?
  rawPayload          Json?
  evaluations         AiSignalEvaluation[]

  @@index([createdAt])
  @@index([symbol, interval, signalType, createdAt])
  @@index([source, createdAt])
}

model AiSignalEvaluation {
  id                  String      @id @default(cuid())
  signalLogId         String
  signalLog           AiSignalLog @relation(fields: [signalLogId], references: [id], onDelete: Cascade)
  horizon             String
  evaluatedAt         DateTime    @default(now())
  priceAtEvaluation   Float?
  priceChangePercent  Float?
  directionCorrect    Boolean?
  score               Float?
  resultLabel         String?
  status              String?

  @@unique([signalLogId, horizon])
  @@index([horizon, evaluatedAt])
  @@index([status])
}

model AiMarketFavorite {
  id         String   @id @default(cuid())
  userId     String
  symbol     String
  displayName String?
  assetClass String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([userId, createdAt])
}

model AiMarketReport {
  id                 String               @id @default(cuid())
  userId             String?
  periodKey          String
  scope              String               @default("GLOBAL")
  status             String               @default("COMPLETED")
  model              String?
  generatedAt        DateTime             @default(now())
  macroSummary       String
  marketRegime       String?
  riskAppetite       String?
  keyTakeaways       Json
  requiredCoverage   Json
  newsSummary        String?
  dataSnapshot       Json?
  rawAiPayload       Json?
  fallbackUsed       Boolean              @default(false)
  disclaimer         String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  user               User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  assets             AiMarketReportAsset[]
  newsItems          AiMarketReportNewsItem[]
  events             AiMarketReportEvent[]

  @@unique([userId, periodKey, scope])
  @@index([generatedAt])
  @@index([userId, generatedAt])
}

model AiMarketReportEvent {
  id        String         @id @default(cuid())
  reportId  String
  userId    String?
  eventType String
  metadata  Json?
  createdAt DateTime       @default(now())
  report    AiMarketReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([reportId, eventType, createdAt])
  @@index([userId, eventType, createdAt])
  @@index([eventType, createdAt])
}

model AiMarketReportAsset {
  id                  String         @id @default(cuid())
  reportId            String
  symbol              String
  displayName         String
  assetClass          String
  category            String?
  lastPrice           Float?
  changePercent       Float?
  signalType          String?
  confidence          Float?
  riskScore           Float?
  opportunityScore    Float?
  technicalCommentary String
  macroCommentary     String?
  newsCommentary      String?
  watchLevels         Json?
  scenarios           Json?
  sourcePayload       Json?
  createdAt           DateTime       @default(now())
  report              AiMarketReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, symbol])
  @@index([symbol, createdAt])
}

model AiMarketReportNewsItem {
  id          String         @id @default(cuid())
  reportId    String
  title       String
  link        String
  source      String
  publishedAt DateTime?
  category    String?
  relevance   Float?
  createdAt   DateTime       @default(now())
  report      AiMarketReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, relevance])
  @@index([category, createdAt])
}

model SubscriptionEmailLog {
  id           String   @id @default(cuid())
  userId       String
  email        String
  emailType    String
  periodKey    String
  subject      String
  sentAt       DateTime @default(now())
  metadata     Json?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, emailType, periodKey])
  @@index([emailType, periodKey])
  @@index([sentAt])
}

model ChatRoom {
  id              String         @id @default(cuid())
  code            String         @unique
  name            String
  type            ChatRoomType
  createdByUserId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdBy       User?          @relation("CreatedChatRooms", fields: [createdByUserId], references: [id], onDelete: SetNull)
  messages        ChatMessage[]
  presences       ChatPresence[]

  @@index([type, createdAt])
  @@index([createdByUserId])
}

model ChatMessage {
  id          String          @id @default(cuid())
  roomId      String
  userId      String
  type        ChatMessageType @default(TEXT)
  body        String
  attachment  Json?
  createdAt   DateTime        @default(now())
  room        ChatRoom        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  pollOptions ChatPollOption[]
  pollVotes   ChatPollVote[]

  @@index([roomId, createdAt])
  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model ChatPresence {
  id         String   @id @default(cuid())
  roomId     String
  userId     String
  lastSeenAt DateTime @default(now())
  room       ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([lastSeenAt])
  @@index([userId, lastSeenAt])
}

model ChatPollOption {
  id        String         @id @default(cuid())
  messageId String
  label     String
  sortOrder Int            @default(0)
  message   ChatMessage    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  votes     ChatPollVote[]

  @@index([messageId, sortOrder])
}

model ChatPollVote {
  id        String         @id @default(cuid())
  messageId String
  optionId  String
  userId    String
  createdAt DateTime       @default(now())
  message   ChatMessage    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  option    ChatPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([optionId])
  @@index([userId, createdAt])
}
